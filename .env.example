MONGO_URI=your_mongodb_atlas_uri
MONGO_DB_NAME=rag_policy_db
MONGO_COLLECTION_NAME=policy_chunks
MONGO_VECTOR_INDEX_NAME=policy_chunks_vector_index
MONGO_COMPLAINT_COLLECTION_NAME=complaints
MONGO_DEPARTMENT_COLLECTION_NAME=departments
MONGO_AREA_COLLECTION_NAME=areas

EMBED_MODEL_NAME=BAAI/bge-m3
EMBED_DEVICE=cpu
EMBED_BATCH_SIZE=32
EMBED_QUERY_SCRIPT=../processing/embed_worker.py
# Windows local: python | Linux/Render native: python3 | Render Docker venv: /app/venv/bin/python
PYTHON_COMMAND=python
# Increase on cloud deployments (e.g. Render) where cold model load can exceed 2 min
EMBED_TIMEOUT_MS=120000

prod_env=false
LLM_PROVIDER=ollama

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=llama3:8b
OLLAMA_NUM_PREDICT=256

GROQ_API_KEY=
GROQ_API_BASE_URL=https://api.groq.com/openai/v1
GROQ_CHAT_MODEL=llama-3.1-8b-instant
GROQ_MAX_TOKENS=256
GROQ_TIMEOUT_MS=60000

ANALYTICS_DEFAULT_WINDOW_DAYS=7
ANALYTICS_MIN_SAMPLE_SIZE=20
ANALYTICS_CONFIDENCE_FLOOR=0.45
ANALYTICS_TIMEOUT_MS=120000

WEATHER_API_PROVIDER=open-meteo
WEATHER_API_KEY=
WEATHER_API_BASE_URL=https://api.open-meteo.com/v1/forecast
WEATHER_GEOCODE_BASE_URL=https://geocoding-api.open-meteo.com/v1/search
WEATHER_LOCATION_QUERY=Bengaluru,IN
WEATHER_LATITUDE=
WEATHER_LONGITUDE=
WEATHER_TIMEZONE=auto

PORT=8080
